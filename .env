# Backend
BACKEND_PORT=8000

# Auth
AUTH_SECRET=
AUTH_EXPIRE_MINUTES=60

# DB
DB_HOST=db
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASS=app_pass
DATABASE_URL=postgresql+psycopg[binary]://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Frontend (Expo)
REACT_NATIVE_PACKAGER_HOSTNAME=127.0.0.1
EXPO_TUNNEL=false
EXPO_DEVTOOLS_LISTEN_ADDRESS=0.0.0.0
EXPO_PUBLIC_API_HOST=${REACT_NATIVE_PACKAGER_HOSTNAME}
EXPO_PUBLIC_API_PORT=8000
EXPO_PUBLIC_API_BASE=http://${EXPO_PUBLIC_API_HOST}:${EXPO_PUBLIC_API_PORT}
EXPO_PUBLIC_FEED_URL=./feed/index.json
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-NTMBH1NCJE

# OLLAMA
OLLAMA_TIMEOUT_S=512
MODELS_DIR="./models"

# RAG docs / indexing
DOCS_DIR=/data/json
RAG_AUTO_INDEX=false
RAG_REBUILD_ON_START=false
RAG_INDEX_FAIL_FAST=false
RAG_REINDEX_ENABLED=true
RAG_AUDIT=1
RAG_AUDIT_MAX_ATTEMPTS=2
RAG_AUDIT_REWRITE=1

# OpenAI
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Ollama
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
RAG_MODEL=llama3.1:8b
AUDIT_MODEL=llama3.1:8b
EMBEDDING_MODEL=mxbai-embed-large


# Chunking
RAG_CHUNK_SIZE=128
RAG_TOP_K=16

# Chroma
CHROMA_DB_DIR=/chroma
CHROMA_COLLECTION_NAME=documents
RAG_CHROMA_SOURCE=gdrive
RAG_CHROMA_GDRIVE_URL=
RAG_CHROMA_S3_BUCKET=
RAG_CHROMA_S3_PREFIX=rag/chroma
RAG_CHROMA_LOCAL_DIR=./chroma_db_seed

# Settings
CURL_MAX_TIME=512
CURL_RETRIES=0
MAX_CHARS=220
TZ_NAME=Asia/Tokyo
HASHTAGS=""
FEED_PATH="frontend/app/public"
LATEST_PATH="frontend/app/public/latest.json"
EXPO_PUBLIC_USE_SLOT=1
EXPO_PUBLIC_SLOT_ROTATE_MS=6500
EXPO_PUBLIC_SLOT_FADE_MS=800
EXPO_PUBLIC_FEED_JSON_URL=""
EXPO_PUBLIC_SHARE_SD_INDEX_URL=""
EXPO_PUBLIC_FEEDBACK_FORM_URL=""

###
EXPO_PUBLIC_API_HOST=127.0.0.1
EXPO_PUBLIC_API_BASE=http://127.0.0.1:8000
EXPO_PUBLIC_GA_MEASUREMENT_ID=

RAG_MODEL=qwen3:8b
AUDIT_MODEL=qwen3:8b

MODE=text2img
LORA_PATH=
LORA_SCALE=0
STEPS=6
GUIDANCE_SCALE=2.0
NEGATIVE=photorealistic, text, watermark, logo, low quality, blurry, underexposed, too dark